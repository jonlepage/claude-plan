{
  "name": "claude-plan",
  "displayName": "Claude Plan — Annotate & Review AI Plans",
  "description": "Annotate markdown plans in preview mode with directives, then send feedback to Claude Code in one click. Select text or hover lines to add notes, review inline, and iterate faster on AI-generated plans.",
  "version": "0.1.1",
  "publisher": "lepasoft-dev",
  "license": "MIT",
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/lepasoft/claude-plan"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Programming Languages"
  ],
  "keywords": [
    "claude",
    "claude code",
    "plan",
    "markdown",
    "annotate",
    "review",
    "AI",
    "directives",
    "feedback"
  ],
  "activationEvents": [
    "onLanguage:markdown"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "claudePlan.showInfo",
        "title": "Claude Plan: Show Info"
      },
      {
        "command": "claudePlan.addAnnotation",
        "title": "Claude Plan: Add Directive"
      },
      {
        "command": "claudePlan.sendToClaude",
        "title": "Claude Plan: Send to Claude Code",
        "icon": "$(sparkle)"
      },
      {
        "command": "claudePlan.clearAll",
        "title": "Claude Plan: Clear All Directives"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "claudePlan.addAnnotation",
          "when": "resourceLangId == markdown && editorHasSelection",
          "group": "1_modification"
        }
      ],
      "editor/title": [
        {
          "command": "claudePlan.sendToClaude",
          "when": "resourceLangId == markdown || activeWebviewPanelId == 'markdown.preview'",
          "group": "navigation"
        }
      ]
    },
    "keybindings": [
      {
        "command": "claudePlan.addAnnotation",
        "key": "insert",
        "when": "resourceLangId == markdown && editorHasSelection"
      },
      {
        "command": "claudePlan.sendToClaude",
        "key": "alt+enter",
        "when": "resourceLangId == markdown || activeWebviewPanelId == 'markdown.preview'"
      }
    ],
    "markdown.previewScripts": [
      "./media/preview-inject.js"
    ],
    "markdown.previewStyles": [
      "./media/preview-inject.css"
    ]
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "typecheck": "tsc --noEmit",
    "package": "vsce package --out release"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.24.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.4.0"
  }
}
